VITE_API_URL=http://localhost:3000
VITE_API_KEY=test_varos_sdk_key_2024
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_HEDERA_NETWORK=testnet
VITE_HEDERA_APP_NAME=Varos MXNH Protocol
VITE_HEDERA_APP_DESCRIPTION=Protocolo de peso mexicano nativo en Hedera

# WalletConnect Project ID (requerido por HashConnect para abrir el modal de wallets).
# Obtén uno en https://cloud.walletconnect.com/ (crea un proyecto y copia el Project ID).
# En el portal de Hedera también aparece la sección WalletConnect con la guía de integración:
# https://portal.hedera.com
VITE_WALLETCONNECT_PROJECT_ID=

# ID del topic de Hedera Consensus Service (HCS) usado por el protocolo para mensajes/consenso.
# Lo usa la app solo para el enlace "Ver topic" en /success. Consúltalo en tu backend,
# en el mirror node o en el despliegue del contrato/topic del protocolo (formato 0.0.xxxxx).
VITE_HCS_TOPIC_ID=0.0.0

# Cuenta Hedera del recolector de comisiones (mismo valor que HEDERA_FEE_COLLECTOR_ID en el backend).
# Usado en /dashboard para mostrar el saldo MXNH del recolector.
VITE_FEE_COLLECTOR_ID=0.0.0
