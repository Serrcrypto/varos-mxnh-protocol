# ============================================================
# Varos MXNH Protocol — Frontend Environment Variables
# Copia este archivo como .env (dev) o configura en Vercel (prod)
# ============================================================

# URL del backend (Railway en produccion, localhost en dev)
# PRODUCCION: https://varos-mxnh-protocol-production.up.railway.app
# DESARROLLO:  http://localhost:3000
VITE_API_URL=http://localhost:3000

# API key del SDK (mismo valor que TEST_API_KEY en el backend)
VITE_API_KEY=vr_live_xxxxxxxxxxxxxxxxxxxx

# Stripe publishable key (pk_test_... para testnet, pk_live_... para produccion)
# Obten en: dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Red de Hedera (testnet | mainnet)
VITE_HEDERA_NETWORK=testnet

# Nombre de la app para HashConnect wallet
VITE_HEDERA_APP_NAME=Varos MXNH Protocol
VITE_HEDERA_APP_DESCRIPTION=Protocolo de peso mexicano nativo en Hedera

# WalletConnect Project ID (requerido por HashConnect)
# Obten en: https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID del topic HCS (mismo que HEDERA_HCS_TOPIC_ID en el backend)
VITE_HCS_TOPIC_ID=0.0.XXXXXX

# Fee Collector account ID (mismo que HEDERA_FEE_COLLECTOR_ID en el backend)
VITE_FEE_COLLECTOR_ID=0.0.8252168
