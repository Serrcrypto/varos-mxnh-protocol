# ============================================================
# Varos MXNH Protocol — Backend Environment Variables
# Copia este archivo como .env y llena los valores reales
# NUNCA commitees el .env con valores reales
# ============================================================

# ── Hedera (4 cuentas obligatorias) ──────────────────────────
HEDERA_NETWORK=testnet

# Operator — paga las transacciones en HBAR
HEDERA_OPERATOR_ID=0.0.XXXXXX
HEDERA_OPERATOR_PRIVATE_KEY=302e020100300506032b657004220420...

# Treasury — emite y quema MXNH
HEDERA_TREASURY_ID=0.0.XXXXXX
HEDERA_TREASURY_PRIVATE_KEY=302e020100300506032b657004220420...

# Compliance — gestiona KYC/AML
HEDERA_COMPLIANCE_ID=0.0.XXXXXX
HEDERA_COMPLIANCE_PRIVATE_KEY=302e020100300506032b657004220420...

# Fee Collector — recibe el 0.5% automatico de cada tx
HEDERA_FEE_COLLECTOR_ID=0.0.8252168
HEDERA_FEE_COLLECTOR_KEY=302e020100300506032b657004220420...

# Token MXNH en HTS
HEDERA_MXNH_TOKEN_ID=0.0.8252633

# HCS Topic para auditoria ISO 20022
HEDERA_HCS_TOPIC_ID=0.0.XXXXXX

# ── Stripe Connect ────────────────────────────────────────────
# Obten en: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Twilio SMS ────────────────────────────────────────────────
# Obten en: console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── SDK Auth ──────────────────────────────────────────────────
# Genera valores unicos y seguros (ej: openssl rand -hex 32)
SDK_ADMIN_KEY=admin_key_super_secreto
TEST_API_KEY=vr_live_xxxxxxxxxxxxxxxxxxxx

# ── Base de datos (Neon PostgreSQL Serverless) ────────────────
# Obten en: neon.tech -> Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── CORS ──────────────────────────────────────────────────────
# URL del frontend en Vercel (sin trailing slash)
# En dev puedes omitir esta variable (acepta todo)
CORS_ORIGIN=https://varos-mxnh-protocol.vercel.app

# ── Node ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
